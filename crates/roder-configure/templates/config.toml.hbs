{{provider_config}}
{{session_store_config}}

[zerolang]
timeout_seconds = 30
artifact_dir = ".zero/roder"

{{config_overrides_toml}}

[dynamic_workflows]
enabled = true
trigger_word_enabled = true
auto_with_ultracode = true
max_concurrent_agents = 16
max_agents_per_run = 1000
default_agent_timeout_seconds = 180
default_run_timeout_seconds = 14400
default_checkpoint_bytes = 1048576
max_report_bytes = 65536
workspace_workflows_dir = ".agents/workflows"
user_workflows_dir = "~/.roder/workflows"

[dynamic_workflows.approval]
require_approval = true
allow_always_for_script_and_workspace = true

# Local usage analytics (never uploaded anywhere). Disable with
# `enabled = false`; `workspace_labels` controls how workspace paths are
# recorded: "full_path" (default), "hashed", or "basename_only".
[analytics]
enabled = true
workspace_labels = "full_path"

# Required environment variables:
{{required_env_comments}}

[config_overrides]
json = '''
{{config_overrides_json}}
'''
