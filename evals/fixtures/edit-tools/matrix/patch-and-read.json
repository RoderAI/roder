{
  "fixtures": [
    {
      "name": "patch-add-update-delete-move",
      "class": "patch-add-update-delete-move",
      "files": {
        "fixture.txt": "old\n",
        "stale.txt": "remove me\n",
        "src/legacy.txt": "keep this body\n"
      },
      "operation": {
        "kind": "patch",
        "patch": "*** Begin Patch\n*** Add File: docs/new.txt\n+brand new\n*** Update File: fixture.txt\n@@\n-old\n+new\n*** Delete File: stale.txt\n*** Update File: src/legacy.txt\n*** Move to: src/modern.txt\n@@\n-keep this body\n+kept and moved body\n*** End Patch\n"
      },
      "expected_files": {
        "fixture.txt": "new\n",
        "docs/new.txt": "brand new\n",
        "src/modern.txt": "kept and moved body\n"
      },
      "absent_files": ["stale.txt", "src/legacy.txt"]
    },
    {
      "name": "patch-missing-context-fails-closed",
