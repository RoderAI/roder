{
  "job_name": "roder-tbench-codex-parity-tools-experiment",
  "jobs_dir": "evals/harbor/jobs",
  "n_attempts": 1,
  "timeout_multiplier": 1.0,
  "agent_setup_timeout_multiplier": 4.0,
  "debug": false,
  "orchestrator": {
    "type": "local",
    "n_concurrent_trials": 4,
    "quiet": false,
    "retry": {
      "max_retries": 0,
      "exclude_exceptions": [
        "RewardFileEmptyError",
        "AgentTimeoutError",
        "VerifierOutputParseError",
        "RewardFileNotFoundError",
        "VerifierTimeoutError"
      ]
    }
  },
  "environment": {
    "type": "docker",
    "force_build": false,
    "delete": false,
    "kwargs": {}
  },
  "verifier": {
    "disable": false
  },
  "agents": [
    {
      "import_path": "roder_harbor_agent:RoderCli",
      "model_name": "codex/gpt-5.5",
      "kwargs": {
        "reasoning": "xhigh",
        "benchmark_guidance_enabled": false,
        "task_ledger_required": false,
        "plan_first_enabled": false,
        "speed_policy_enabled": false,
        "policy_mode": "bypass",
        "include_prebuilt_binary": "true",
        "include_local_source": "false",
        "agent_timeout_multiplier_hint": 1.0,
        "policy_block_max_retries": 2,
        "tool_allowlist": "read_file,list_files,write_file,grep,glob,shell,exec_command,write_stdin,unified_exec,apply_patch,edit,multi_edit,view_image",
        "reliability_max_consecutive_tool_failures": 24,
        "reliability_max_model_calls_per_turn": 400
      },
      "env": {}
    }
  ],
  "datasets": [
    {
      "registry": {
        "url": "https://raw.githubusercontent.com/laude-institute/harbor/main/registry.json"
      },
      "name": "terminal-bench",
      "version": "2.0"
    }
  ],
  "tasks": [],
  "artifacts": [
    "/logs/agent/roder-cli.txt",
    "/logs/agent/roder-events.jsonl",
    "/logs/agent/roder-stderr.txt",
    "/logs/agent/roder-last-message.txt",
    "/logs/agent/setup-summary.txt",
    "/logs/agent/roder-run-summary.json"
  ]
}
